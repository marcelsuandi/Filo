# =============================================================================
# BACKEND ENVIRONMENT (Express + Sequelize)
# Local dev: cp .env.example .env  (inside Docker these come from root .env)
# =============================================================================
NODE_ENV=development
PORT=3000

# CORS: comma-separated origins, or * for all
CORS_ORIGIN=http://localhost:5173

# --- Database (MariaDB via Sequelize) --------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=filo_db
DB_USER=filo_user
DB_PASSWORD=change_me_strong_password
DB_DIALECT=mariadb
# Set true ONLY in dev to let Sequelize align tables. The SQL migrations are
# the source of truth in production, so keep this false there.
DB_SYNC=false

# --- App -------------------------------------------------------------------
# Salt used to hash visitor/wish IP addresses before storing them.
IP_HASH_SALT=change_me_random_salt
# Default baby slug used when a request does not specify ?baby=
DEFAULT_BABY_SLUG=filomena
