# =============================================================================
# ROOT ENVIRONMENT (consumed by docker-compose)
# Copy this file to ".env" and adjust the values before running.
#   cp .env.example .env
# =============================================================================

# --- General ---------------------------------------------------------------
NODE_ENV=production

# --- Nginx (public entry point) --------------------------------------------
NGINX_PORT=80          # ganti mis. 8085 bila port 80 sudah terpakai

# --- Backend ---------------------------------------------------------------
BACKEND_PORT=3000
# Allowed CORS origin(s). Use the public URL in production, e.g. https://filomena.com
CORS_ORIGIN=*

# --- Frontend (build-time) -------------------------------------------------
# Base URL the frontend uses to reach the API. Through the nginx proxy it is /api
VITE_API_BASE_URL=/api

# --- Database (MariaDB) ----------------------------------------------------
DB_NAME=filo_db
DB_USER=filo_user
DB_PASSWORD=change_me_strong_password
DB_ROOT_PASSWORD=change_me_strong_root_password

# --- phpMyAdmin ------------------------------------------------------------
PMA_PORT=8080
