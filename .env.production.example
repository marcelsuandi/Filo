# =============================================================================
# PRODUCTION ENVIRONMENT  ->  copy to ".env" on the server and edit.
#   cp .env.production.example .env && chmod 600 .env
# Generate strong secrets, e.g.:  openssl rand -base64 24
# =============================================================================

# --- Domain & TLS ----------------------------------------------------------
DOMAIN=filomena.example.com
CERTBOT_EMAIL=you@example.com
# Use Let's Encrypt staging (1) while testing to avoid rate limits, then 0.
CERTBOT_STAGING=0

# --- Ports (nginx) -----------------------------------------------------------
# Ganti bila 80/443 sudah dipakai layanan lain di host (mis. NGINX_PORT=8085).
NGINX_PORT=80
NGINX_HTTPS_PORT=443

# --- App -------------------------------------------------------------------
NODE_ENV=production
# Frontend talks to the API through the same origin via /api
VITE_API_BASE_URL=/api
# Lock CORS to your real origin in production
CORS_ORIGIN=https://filomena.example.com
IP_HASH_SALT=change_me_long_random_value
DEFAULT_BABY_SLUG=filomena

# --- Database (NOT exposed publicly) ---------------------------------------
DB_NAME=filo_db
DB_USER=filo_user
DB_PASSWORD=change_me_strong_password
DB_ROOT_PASSWORD=change_me_strong_root_password

# --- phpMyAdmin (bound to 127.0.0.1 only; reach via SSH tunnel) ------------
PMA_PORT=8080
PMA_ABSOLUTE_URI=http://localhost:8080/
