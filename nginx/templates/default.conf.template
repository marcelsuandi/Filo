upstream filo_backend  { server backend:3000; keepalive 16; }
upstream filo_frontend { server frontend:80;  keepalive 16; }

# ---- HTTP: ACME challenge + redirect to HTTPS ----
server {
    listen 80;
    listen [::]:80;
    server_name ${DOMAIN} www.${DOMAIN};

    # Container/uptime healthcheck without redirect
    location = /healthz {
        access_log off;
        add_header Content-Type text/plain;
        return 200 'ok';
    }

    # Let's Encrypt http-01 challenge
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ---- HTTPS: the application ----
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name ${DOMAIN} www.${DOMAIN};

    ssl_certificate     /etc/letsencrypt/live/${DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${DOMAIN}/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/${DOMAIN}/chain.pem;
    include /etc/nginx/ssl-params.conf;

    location = /healthz {
        access_log off;
        add_header Content-Type text/plain;
        return 200 'ok';
    }

    # API -> backend (rate limited)
    location /api/ {
        limit_req zone=api burst=20 nodelay;
        limit_conn addr 20;
        proxy_pass http://filo_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }

    # Frontend SPA
    location / {
        limit_req zone=general burst=50 nodelay;
        proxy_pass http://filo_frontend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # OPTIONAL — expose phpMyAdmin over HTTPS behind IP allowlist + basic auth.
    # Prefer the SSH tunnel instead. To enable: create nginx/.htpasswd and
    # mount it, then uncomment.
    # location /pma/ {
    #     allow 203.0.113.10;   # your office/home IP
    #     deny all;
    #     auth_basic "Restricted";
    #     auth_basic_user_file /etc/nginx/.htpasswd;
    #     proxy_pass http://phpmyadmin:80/;
    #     proxy_set_header Host $host;
    #     proxy_set_header X-Forwarded-Proto $scheme;
    # }
}
